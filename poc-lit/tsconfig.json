{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    // Lit's @customElement/@property decorators rely on the legacy decorator
    // semantics; useDefineForClassFields:false keeps decorated fields working
    // as reactive properties instead of being clobbered by class field defs.
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "include": ["src"]
}
